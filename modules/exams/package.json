{
  "name": "@viccoboard/exams",
  "version": "0.1.0",
  "description": "KBR domain module - exam builder and correction",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rule-packs": {
      "types": "./dist/rule-packs/index.d.ts",
      "import": "./dist/rule-packs/index.js"
    }
  },
