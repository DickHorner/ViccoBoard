    "test": "jest",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@viccoboard/core": "*",
    "@viccoboard/storage": "*",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/uuid": "^9.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
